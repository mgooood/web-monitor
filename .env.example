# This monitor uses Playwright to open a real Chrome browser and bypass Cloudflare bot detection.
# Make sure you have run: npm install && npx playwright install chromium

# WebTrac search configuration
# SEARCH_BASE_URL is the base search page for the WebTrac site.
SEARCH_BASE_URL=https://vaarlingtonweb.myvscloud.com/webtrac/web/search.html

# SEARCH_TYPE is the class type code. For woodworking, this is WOOD.
SEARCH_TYPE=WOOD

# SEARCH_MODULE is the WebTrac module. For Activity Registration, this is AR.
SEARCH_MODULE=AR

# Status keywords
# These are the exact text strings that appear in the WebTrac availability column.
STATUS_AVAILABLE=Available
STATUS_WAITLIST=Waitlist
STATUS_UNAVAILABLE=Unavailable

# Logging settings
# Set to true to include Available classes in the console output.
NOTIFY_ON_AVAILABLE=true

# Set to true to include Waitlist-only classes in the console output.
NOTIFY_ON_WAITLIST=false

# Polling interval in minutes
# How often the monitor should check the WebTrac site.
# 10 minutes is recommended to avoid being rate-limited.
CHECK_INTERVAL_MINUTES=10
